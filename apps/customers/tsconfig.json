{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@superset/typescript/base.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"types": ["vite/client"],
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src", "vite.config.ts"],
	"exclude": ["node_modules", "dist"]
}
