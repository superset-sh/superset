{
	"extends": "@superset/typescript/internal-package.json",
	"compilerOptions": {
		"rootDir": "src",
		"jsx": "react-jsx",
		"declaration": false,
		"declarationMap": false,
		"emitDeclarationOnly": false,
		"noEmit": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}
