{
	"extends": "@superset/typescript/react-internal-package.json",
	"compilerOptions": {
		"baseUrl": ".",
		"rootDir": ".",
		"paths": {
			"@superset/agent": ["../agent/src/index.ts"],
			"@/*": ["./*"],
			"@/core/*": ["./core/*"],
			"@/shared/*": ["./shared/*"],
			"@/features/*": ["./features/*"]
		},
		"noEmit": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"isolatedModules": false
	},
	"include": ["."],
	"exclude": ["node_modules", "dist", "coverage"]
}
